<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
        http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">
    
    <!-- Homepage -->
    <url>
        <loc>https://fbbstore.com/</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>
    
    <!-- Shop -->
    <url>
        <loc>https://fbbstore.com/shop</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>
    
    <!-- About -->
    <url>
        <loc>https://fbbstore.com/about</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    
    <!-- Contact -->
    <url>
        <loc>https://fbbstore.com/contact</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    
    <!-- Sellers -->
    <url>
        <loc>https://fbbstore.com/seller-list</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.7</priority>
    </url>
    
    <!-- Category pages (dynamic - these would be generated from your data) -->
    <url>
        <loc>https://fbbstore.com/seller-list/:sellerId/category/:categoryId</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <!-- Subcategory pages -->
    <url>
        <loc>https://fbbstore.com/products/:sellerId/:categoryId/:subcategoryId</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <!-- Product pages (dynamic - these would be generated from your product data) -->
    <url>
        <loc>https://fbbstore.com/product/:productId</loc>
        <lastmod>2024-12-20</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.7</priority>
    </url>
    
</urlset>